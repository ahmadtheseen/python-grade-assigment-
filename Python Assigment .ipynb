   "source": [
    "# Ask student marks\n",
    "marks = int(input(\"Enter student marks: \"))\n",
    "\n",
    "# Classify grade\n",
    "if marks > 80:\n",
    "    print(\"Grade A\")\n",
    "\n",
    "elif marks >= 60:\n",
    "    print(\"Grade B\")\n",
    "\n",
    "elif marks >= 50:\n",
    "    print(\"Grade C\")\n",
    "\n",
    "elif marks >= 40:\n",
    "    print(\"Grade D\")\n",
    "\n",
    "else:\n",
    "    print(\"Failed\")"
   ]
  },
